<!DOCTYPE html>
<html>
<head>
<title>My Clothes Store</title>

<style>
body{
  font-family: Arial;
  background-color:#f5f5f5;
  text-align:center;
}

header{
  background-color:black;
  color:white;
  padding:15px;
}

.product{
  border:1px solid #ccc;
  width:200px;
  display:inline-block;
  margin:20px;
  padding:10px;
  background:white;
}

button{
  background:black;
  color:white;
  padding:10px;
  border:none;
}
</style>

</head>

<body>

<header>
<h1>Bharath Fashion Store</h1>
<p>Best Clothes Collection</p>
</header>

<div class="product">
<img src="https://via.placeholder.com/150">
<h3>T-Shirt</h3>
<p>Price: ₹499</p>
<button>Buy Now</button>
</div>

<div class="product">
<img src="https://via.placeholder.com/150">
<h3>Shirt</h3>
<p>Price: ₹899</p>
<button>Buy Now</button>
</div>

<div class="product">
<img src="https://via.placeholder.com/150">
<h3>Jeans</h3>
<p>Price: ₹1299</p>
<button>Buy Now</button>
</div>

</body>
</html>
